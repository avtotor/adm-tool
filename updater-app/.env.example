# URL сервера adm-tool, доступный с планшета в локалке.
# Пример: http://192.168.1.10:8080
EXPO_PUBLIC_SERVER_URL=http://192.168.1.10:8080

# Имя пакета целевого приложения, которое должен обновлять апдейтер.
# Например: com.company.factoryapp
EXPO_PUBLIC_TARGET_PACKAGE=com.example.app

# Интервал heartbeat в секундах (по умолчанию 300 = 5 минут).
EXPO_PUBLIC_HEARTBEAT_SECONDS=300
